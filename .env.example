# Pebble runs entirely on local Ollama.

OLLAMA_HOST=http://127.0.0.1:11434

# Text model used for Polish. Default is qwen3-coder:30b — strong writing on
# Apple Silicon. Override with any chat-capable Ollama model you have pulled.
POLISH_MODEL=qwen3-coder:30b

# Global shortcut for "polish whatever's in my clipboard right now".
# Electron Accelerator format. Default: Cmd+Alt+P (mac) / Ctrl+Alt+P (others).
PEBBLE_POLISH_SHORTCUT=CommandOrControl+Alt+P
